#!/bin/sh -e
#
# http://github.com/mitchweaver/bin
#
# wrapper around my commonly used imagemagick commands
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - -

die() { >&2 echo "$*" ; exit 1 ; }

# Source colors from current running theme.
if [ -f ~/src/dots/themes/current ] ; then
    # shellcheck disable=SC1090
    . ~/src/dots/themes/current
else
    # If not found, it is the usual
    # off-white yellowish background I use
    background='#d9d5ba'
fi

# default file name if no $3 is given
DEFAULT=out.png

usage() {
>&2 cat <<EOF
Usage: mag [options] file.png

Options:
---------------
-b    |  blur background (0x4)
-s    |  swap background colors
-t    |  make white bg transparent
-r    |  rotate right
-25   |  resize image to 25%
-50   |  resize image to 50%
-75   |  resize image to 75%
EOF
exit 1
}

case ${1#-} in
    b)
        [ -f "$2" ] || die "No such file: '$2'"

        magick convert -quiet "$2" \
            -blur 0x4 \
            "${3:-$DEFAULT}"
        ;;
    s)
        [ -f "$2" ] || die "No such file: '$2'"

        # swap background colors, preserving black text
        magick convert -quiet "$2" -fill "$background" -fuzz 80% +opaque "#000000" "${3:-$DEFAULT}"
        ;;
    t)
        [ -f "$2" ] || die "No such file: '$2'"

        # turns white background transparent
        magick convert -quiet "$2" -transparent white "${3:-$DEFAULT}"
        ;;
    r)
        [ -f "$2" ] || die "No such file: '$2'"

        # rotate right
        magick convert -quiet -rotate 90 -quality 100 "$2" "${3:-$DEFAULT}"
        ;;
    25|50|75)
        [ -f "$2" ] || die "No such file: '$2'"

        # make copy as mogrify has no way of outputting
        # to a different file
        cp -f "$2" "${3:-$DEFAULT}" 2>/dev/null ||:
        # resizes an image to a given percent
        mogrify -resize "${1#-}%x${1#-}%" "${3:-$DEFAULT}"
        ;;
    *)
        usage
esac

