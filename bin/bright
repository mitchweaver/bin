#!/bin/sh
#
# http://github.com/mitchweaver/bin
#
# brightness wrapper
# supports xbacklight/acpilight on Linux and backlight on FreeBSD
#

usage() {
    >&2 printf '%s\n' "Usage: ${0##*/} [-i] [-d] [-s value]"
    exit 1
}

set_br() {
    case $(uname) in
        FreeBSD)
            backlight "$(clamp "$1")"
            ;;
        Linux)
            if command -v xbacklight ; then
                xbacklight -set "$(clamp "$1")"
            elif command -v brightnessctl >/dev/null ; then
                brightnessctl -q set "${1}%"
            fi
    esac
}

get_br() {
    case $(uname) in
        FreeBSD)
            br=$(backlight -q)
            ;;
        Linux)
            # if we have on wayland acpilight or on X11 xbacklight
            # then this becomes very easy
            if command -v xbacklight ; then
                br=$(xbacklight -get)
            elif command -v brightnessctl >/dev/null ; then
                # but if we don't... we have to do some math
                # and a bit of shell trickery for the floating bits
                max=$(brightnessctl -q max)
                current=$(brightnessctl -q get)
                float=$(echo "scale=2; $current / $max" | bc)

                # chop off leading period if exists
                float=${float#\.}

                # chop off leading zero if exists
                float=${float#0}

                # pretty-clamp if 100% or 0%
                case $float in
                    1.00)
                        float=100
                        ;;
                esac

                br="$float"
            fi
    esac
    printf '%s\n' "${br%.*}"
}



isnumber() {
    for i ; do
        case $i in
            ''|*[!0-9]*)
                return 1
        esac
    done
}

clamp() {
    isnumber "$1" || usage

    case $1 in
        100*)
            echo 100
            ;;
        0|-*)
            echo 1
            ;;
        *)
            printf '%s\n' "$1"
    esac
}

main() {
    case ${1#-} in
        h)
            usage
            ;;
        i)
            set_br $(( $(get_br) + ${2:-${BRIGHT_INCREMENT:-7}} ))
            ;;
        d)
            set_br $(( $(get_br) - ${2:-${BRIGHT_INCREMENT:-7}} ))
            ;;
        s)
            if [ "$2" ] ; then
                set_br "$2"
            else
                usage
            fi
            ;;
        *)
            printf '%s%%\n' "$(get_br)"
    esac
}

main "$@"
